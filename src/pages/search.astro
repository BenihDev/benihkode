---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search — BenihKode" description="Search across blog posts, projects, and ideas">
	<section style="padding-top: 4rem; min-height: 60vh;">
		<div class="container">
			<div class="section-label">Search</div>
			<h1 class="section-title animate-on-scroll">Search the Garden</h1>
			<p class="section-desc animate-on-scroll">Find articles, projects, and ideas across the entire site.</p>
			
			<div class="search-container">
				<div id="search" class="search-wrapper"></div>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.search-container {
		max-width: 720px; margin: 0 auto; padding: 2rem 0;
	}
	.search-wrapper {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: var(--radius-sm);
		padding: 2rem;
	}
	
	/* Pagefind styles - will be injected by pagefind */
	:global(.pagefind-ui) {
		font-family: 'Inter', sans-serif;
	}
	:global(.pagefind-ui__form) {
		position: relative;
		margin-bottom: 2rem;
	}
	:global(.pagefind-ui__search-input) {
		width: 100%;
		padding: 1rem 1.25rem;
		font-size: 1rem;
		background: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		color: var(--text-primary);
		transition: border-color 0.2s;
	}
	:global(.pagefind-ui__search-input:focus) {
		outline: none;
		border-color: var(--accent);
		box-shadow: 0 0 0 3px var(--accent-glow);
	}
	:global(.pagefind-ui__results-area) {
		min-height: 200px;
	}
	:global(.pagefind-ui__result) {
		margin-bottom: 1.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--border);
	}
	:global(.pagefind-ui__result:last-child) {
		border-bottom: none;
	}
	:global(.pagefind-ui__result-title) {
		margin-bottom: 0.5rem;
	}
	:global(.pagefind-ui__result-title a) {
		color: var(--text-primary);
		text-decoration: none;
		font-weight: 600;
		font-size: 1.1rem;
	}
	:global(.pagefind-ui__result-title a:hover) {
		color: var(--accent);
	}
	:global(.pagefind-ui__result-excerpt) {
		color: var(--text-secondary);
		font-size: 0.9rem;
		line-height: 1.6;
	}
	:global(.pagefind-ui__result-excerpt mark) {
		background: var(--glass-border);
		color: var(--accent);
		padding: 0.1rem 0.25rem;
		border-radius: 2px;
	}
	:global(.pagefind-ui__message) {
		color: var(--text-muted);
		font-style: italic;
	}
</style>

<!-- Load Pagefind UI library -->
<script is:inline src="/pagefind/pagefind-ui.js" defer></script>

<!-- Initialize Pagefind UI -->
<script is:inline>
	// Initialize Pagefind UI after the library loads
	function initPagefind() {
		const searchElement = document.getElementById('search');
		if (searchElement && !searchElement.hasAttribute('data-initialized')) {
			searchElement.setAttribute('data-initialized', 'true');
			new PagefindUI({
				element: '#search',
				showSubResults: true,
				excerptLength: 30,
				pageSize: 10,
				resetStyles: false
			});
		}
	}

	// Check if PagefindUI is already loaded (HMR or fast navigation)
	if (typeof PagefindUI !== 'undefined') {
		initPagefind();
	} else {
		// Wait for the pagefind script to load from the built output
		document.addEventListener('DOMContentLoaded', function() {
			const checkReady = setInterval(() => {
				if (typeof PagefindUI !== 'undefined') {
					clearInterval(checkReady);
					initPagefind();
				}
			}, 100);
		});
	}
</script>