---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const tools = (await getCollection('projects')).filter(p => p.data.category === 'tool');
	return tools.map(tool => ({
		params: { slug: tool.id },
		props: tool,
	}));
}

type Props = CollectionEntry<'projects'>;

const tool = Astro.props;
const { Content } = await render(tool);
---

<BaseLayout title={`${tool.data.title} — Tools`} description={tool.data.description}>
	<article style="padding-top: 4rem;">
		<div class="container">
			<a href="/tools" class="back-link">← Back to Tools</a>

			<div class="project-header">
				<div class="project-meta">
					<div class="project-emoji">{tool.data.emoji}</div>
					<div class="tech-stack">
						{tool.data.techStack.map(tech => (
							<span class="tech-badge">{tech}</span>
						))}
						<span class="category-badge">CLI Tool</span>
					</div>
				</div>
				<h1>{tool.data.title}</h1>
				<p class="project-description">{tool.data.description}</p>

				<div class="project-links">
					{tool.data.npmPackage && (
						<a href={`https://www.npmjs.com/package/${tool.data.npmPackage}`} class="project-link npm-link" target="_blank" rel="noopener noreferrer">
							npm
						</a>
					)}
					{tool.data.githubUrl && (
						<a href={tool.data.githubUrl} class="project-link github-link" target="_blank" rel="noopener noreferrer">
							GitHub
						</a>
					)}
				</div>

				{tool.data.installCommand && (
					<div class="install-section">
						<div class="install-label">Install</div>
						<code class="install-command">{tool.data.installCommand}</code>
					</div>
				)}
			</div>

			<div class="project-content">
				<Content />
			</div>

			{tool.data.hasPrivacyPolicy && (
				<a href={`/projects/${tool.id}/privacy-policy`} class="privacy-link">
					Privacy Policy
				</a>
			)}
		</div>
	</article>
</BaseLayout>

<style>
	.back-link {
		display: inline-block; margin-bottom: 2rem; color: var(--text-secondary);
		text-decoration: none; transition: color 0.3s ease;
	}
	.back-link:hover { color: var(--accent); }

	.project-header {
		margin-bottom: 3rem;
	}
	.project-meta {
		display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;
	}
	.project-emoji {
		font-size: 4rem;
	}
	.tech-stack {
		display: flex; gap: 0.5rem; flex-wrap: wrap;
	}
	.tech-badge {
		font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
		padding: 0.25rem 0.6rem; background: var(--bg-card);
		border: 1px solid var(--border); border-radius: 4px;
		color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.04em;
	}
	.category-badge {
		font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;
		padding: 0.25rem 0.6rem; background: var(--accent);
		border: 1px solid transparent; border-radius: 4px;
		color: var(--bg-primary); text-transform: uppercase; letter-spacing: 0.04em;
		font-weight: 600;
	}
	h1 {
		font-size: 2.5rem; font-weight: 800; margin-bottom: 0.75rem;
		line-height: 1.2; color: var(--text-primary);
	}
	.project-description {
		font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 1.5rem;
		line-height: 1.6;
	}
	.project-links {
		display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1.5rem;
	}
	.project-link {
		display: inline-block; padding: 0.75rem 1.5rem;
		background: var(--accent); color: var(--bg-primary);
		text-decoration: none; border-radius: var(--radius);
		font-weight: 600; transition: all 0.3s ease; font-size: 0.9rem;
	}
	.project-link:hover {
		transform: translateY(-2px); box-shadow: 0 8px 16px var(--accent-glow);
	}
	.npm-link {
		background: #cb3837;
	}
	.npm-link:hover {
		box-shadow: 0 8px 16px rgba(203, 56, 55, 0.3);
	}
	.github-link {
		background: var(--bg-card); color: var(--text-primary);
		border: 1px solid var(--border);
	}
	.github-link:hover {
		border-color: var(--accent); color: var(--accent);
		box-shadow: 0 8px 16px var(--accent-glow);
	}

	.install-section {
		margin-bottom: 2rem; padding: 1.25rem 1.5rem;
		background: var(--bg-card); border: 1px solid var(--border);
		border-radius: var(--radius);
	}
	.install-label {
		font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
		text-transform: uppercase; letter-spacing: 0.08em;
		color: var(--text-muted); margin-bottom: 0.5rem;
	}
	.install-command {
		font-family: 'JetBrains Mono', monospace; font-size: 0.95rem;
		color: var(--accent); display: block; user-select: all;
	}

	.project-content {
		max-width: 720px; line-height: 1.8;
	}
	.project-content :global(h2) {
		margin-top: 2.5rem; margin-bottom: 1rem; font-size: 1.8rem;
		color: var(--text-primary);
	}
	.project-content :global(h3) {
		margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.4rem;
		color: var(--text-primary);
	}
	.project-content :global(p) {
		margin-bottom: 1.25rem; color: var(--text-secondary);
	}
	.project-content :global(ul) {
		list-style: disc; padding-left: 1.5rem; margin-bottom: 1.25rem;
	}
	.project-content :global(li) {
		margin-bottom: 0.5rem; color: var(--text-secondary);
	}
	.project-content :global(a) {
		color: var(--accent); text-decoration: none;
	}
	.project-content :global(a:hover) {
		text-decoration: underline;
	}
	.project-content :global(pre) {
		background: var(--bg-card); border: 1px solid var(--border);
		border-radius: var(--radius); padding: 1.25rem;
		overflow-x: auto; margin-bottom: 1.5rem;
	}
	.project-content :global(code) {
		font-family: 'JetBrains Mono', monospace; font-size: 0.9rem;
	}

	.privacy-link {
		display: inline-block; margin-top: 2rem; padding: 0.5rem 1rem;
		background: var(--bg-card); border: 1px solid var(--border);
		border-radius: var(--radius); color: var(--text-secondary);
		text-decoration: none; font-size: 0.9rem; transition: all 0.3s ease;
	}
	.privacy-link:hover {
		color: var(--accent); border-color: var(--accent);
	}

	@media (max-width: 768px) {
		h1 { font-size: 2rem; }
		.project-emoji { font-size: 3rem; }
		.project-content { font-size: 0.95rem; }
		.project-links { flex-direction: column; }
		.project-link { text-align: center; }
	}
</style>
