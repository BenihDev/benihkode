---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PortfolioCard from '../components/PortfolioCard.astro';
import JournalEntry from '../components/JournalEntry.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const [ideasRaw, projectsRaw, blogRaw] = await Promise.all([
	getCollection('ideas'),
	getCollection('projects'),
	getCollection('blog'),
]);

const ideas = ideasRaw.sort((a, b) => a.data.order - b.data.order).slice(0, 4);
const projects = projectsRaw.sort((a, b) => a.data.order - b.data.order).slice(0, 4);
const posts = blogRaw.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 4);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<Hero />

	<div class="section-divider"></div>

	<!-- Product Ideas Section -->
	<section id="prd">
		<div class="container">
			<div class="section-label">01 — Ideas</div>
			<div class="section-header animate-on-scroll">
				<h2 class="section-title">Product Ideas</h2>
				<a href="/ideas" class="view-all-link">View all Ideas &rarr;</a>
			</div>
			<p class="section-desc animate-on-scroll">Every project starts as an idea. Here are the seeds waiting to be planted, with specs and dreams attached.</p>
			<div class="prd-grid stagger-children">
				{ideas.map(idea => (
					<ProjectCard
						title={idea.data.title}
						description={idea.data.description}
						status={idea.data.status}
						meta={idea.data.meta}
						slug={idea.id}
					/>
				))}
			</div>
		</div>
	</section>

	<div class="section-divider"></div>

	<!-- Portfolio Section -->
	<section id="portfolio">
		<div class="container">
			<div class="section-label">02 — Portfolio</div>
			<div class="section-header animate-on-scroll">
				<h2 class="section-title">Shipped Projects</h2>
				<a href="/projects" class="view-all-link">View all Projects &rarr;</a>
			</div>
			<p class="section-desc animate-on-scroll">From seed to harvest. These projects made it out of the garden and into the wild.</p>
			<div class="portfolio-grid stagger-children">
				{projects.map((project, i) => (
					<PortfolioCard
						title={project.data.title}
						description={project.data.description}
						emoji={project.data.emoji}
						techStack={project.data.techStack}
						slug={project.id}
						index={i}
					/>
				))}
			</div>
		</div>
	</section>

	<div class="section-divider"></div>

	<!-- Dev Journal Section -->
	<section id="blog">
		<div class="container">
			<div class="section-label">03 — Journal</div>
			<div class="section-header animate-on-scroll">
				<h2 class="section-title">Dev Journal</h2>
				<a href="/blog" class="view-all-link">View all Posts &rarr;</a>
			</div>
			<p class="section-desc animate-on-scroll">Notes, learnings, and stories from the garden. Growing in public, one post at a time.</p>
			<div class="journal-timeline">
				{posts.map(post => (
					<JournalEntry
						date={post.data.pubDate}
						title={post.data.title}
						excerpt={post.data.description}
						tags={post.data.tags}
						slug={post.id}
					/>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin-bottom: 0.5rem;
	}
	.section-header .section-title {
		margin-bottom: 0;
	}
	.view-all-link {
		font-size: 0.95rem;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s ease;
		font-family: var(--font-mono);
	}
	.view-all-link:hover {
		color: var(--accent);
	}
	.prd-grid {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
		gap: 1.25rem;
	}
	.portfolio-grid {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 1.5rem;
	}
	.journal-timeline {
		position: relative; padding-left: 2rem; max-width: 680px;
		border-left: 1px solid var(--border);
	}
	@media (max-width: 768px) {
		.prd-grid, .portfolio-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
