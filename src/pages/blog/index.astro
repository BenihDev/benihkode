---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import JournalEntry from '../../components/JournalEntry.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout title="Dev Journal — BenihKode" description="Notes, learnings, and stories from the garden.">
	<section style="padding-top: 4rem;">
		<div class="container">
			<div class="section-label">Journal</div>
			<h1 class="section-title animate-on-scroll">Dev Journal</h1>
			<p class="section-desc animate-on-scroll">Notes, learnings, and stories from the garden. Growing in public, one post at a time.</p>
			<div class="journal-timeline">
				{posts.map(post => (
					<JournalEntry
						date={post.data.pubDate}
						title={post.data.title}
						excerpt={post.data.description}
						tags={post.data.tags}
						slug={post.id}
					/>
				))}
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	.journal-timeline {
		position: relative; padding-left: 2rem; max-width: 680px;
		border-left: 1px solid var(--border);
	}
</style>
