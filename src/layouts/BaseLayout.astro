---
import Analytics from '@vercel/analytics/astro';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_EMAIL } from '../consts';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

// Schema.org structured data
const schema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": "https://benihkode.web.id/#organization",
			"name": SITE_TITLE,
			"description": SITE_DESCRIPTION,
			"url": "https://benihkode.web.id",
			"email": SITE_EMAIL,
			"sameAs": [
				"https://github.com/BenihDev",
				"https://twitter.com/benihkode",
				"https://linkedin.com/company/benihkode"
			]
		},
		{
			"@type": "WebSite",
			"@id": "https://benihkode.web.id/#website",
			"url": "https://benihkode.web.id",
			"name": SITE_TITLE,
			"description": SITE_DESCRIPTION,
			"publisher": {
				"@id": "https://benihkode.web.id/#organization"
			},
			"potentialAction": {
				"@type": "SearchAction",
				"target": {
					"@type": "EntryPoint",
					"urlTemplate": "https://benihkode.web.id/search?q={search_term_string}"
				},
				"query-input": "required name=search_term_string"
			}
		},
		{
			"@type": "WebPage",
			"@id": `${Astro.url}#webpage`,
			"url": Astro.url,
			"name": title,
			"description": description,
			"isPartOf": {
				"@id": "https://benihkode.web.id/#website"
			},
			"about": {
				"@id": "https://benihkode.web.id/#organization"
			},
			"datePublished": "2024-01-01",
			"dateModified": new Date().toISOString().split('T')[0]
		}
	]
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<Analytics />
		<!-- Schema.org structured data -->
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
	</head>
	<body>
		<div class="scroll-progress-container"><div class="scroll-progress" id="scrollProgress"></div></div>
		<div class="ambient-glow glow-1"></div>
		<div class="ambient-glow glow-2"></div>
		<div class="ambient-glow glow-3"></div>
		<div class="dot-pattern"></div>

		<Header />
		<main>
			<slot />
		</main>
		<Footer />

		<script>
			// Scroll progress bar
			// ⚡ Bolt Optimization: Use requestAnimationFrame and { passive: true }
			// to throttle scroll events and prevent main thread blocking, ensuring smooth 60fps scrolling.
			let ticking = false;
			window.addEventListener('scroll', () => {
				if (!ticking) {
					window.requestAnimationFrame(() => {
						const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
						const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
						const scrolled = (winScroll / height) * 100;
						const bar = document.getElementById('scrollProgress');
						if (bar) bar.style.width = scrolled + '%';
						ticking = false;
					});
					ticking = true;
				}
			}, { passive: true });

			// Scroll-reveal animations
			// ⚡ Bolt Optimization: Wrap observer setup in requestIdleCallback to avoid blocking main thread on load
			// and use observer.unobserve() to prevent redundant callback executions once elements are visible.
			const initObserver = () => {
				const observer = new IntersectionObserver((entries, obs) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('visible');
							obs.unobserve(entry.target); // Stop tracking elements already revealed
						}
					});
				}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

				document.querySelectorAll('.animate-on-scroll, .blog-post').forEach(el => observer.observe(el));
			};

			if ('requestIdleCallback' in window) {
				requestIdleCallback(initObserver);
			} else {
				setTimeout(initObserver, 1);
			}

			// Smooth scroll for anchor links
			document.querySelectorAll('a[href^="#"], a[href^="/#"]').forEach(link => {
				link.addEventListener('click', (e) => {
					const href = (link as HTMLAnchorElement).getAttribute('href') || '';
					const hash = href.startsWith('/#') ? href.slice(1) : href;
					if (hash === '#') return;
					const target = document.querySelector(hash);
					if (target) {
						e.preventDefault();
						const headerH = document.querySelector('header')?.offsetHeight || 0;
						window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - headerH - 20, behavior: 'smooth' });
					}
				});
			});
		</script>
	</body>
</html>
